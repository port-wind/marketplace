---
import '../styles/global.css';

const {
  title = 'Curl Crypto',
  description = 'Decrypt encrypted curl request parameters and encrypt payloads for test-service calls.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const basePath = import.meta.env.BASE_URL;
const withBase = (path = '') => `${basePath.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="icon" href={withBase('logo.svg')} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-shell">
      <div class="page-glow page-glow-one"></div>
      <div class="page-glow page-glow-two"></div>
      <header class="site-header">
        <a class="brand" href={withBase()}>
          <img src={withBase('logo.svg')} alt="Curl Crypto logo" />
          <span>Curl Crypto</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={withBase()}>Home</a>
          <a href={withBase('docs/')}>Docs</a>
          <a href="https://github.com/leeguooooo/curl-crypto-plugin">GitHub</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>Curl Crypto</strong>
          <p>Decrypt encrypted curl payloads and prepare request bodies for encrypted test services.</p>
        </div>
        <div class="footer-links">
          <a href={withBase('docs/getting-started/')}>Getting Started</a>
          <a href={withBase('docs/commands/')}>Commands</a>
          <a href="https://github.com/leeguooooo/curl-crypto-plugin">Repository</a>
        </div>
      </footer>
    </div>
  </body>
</html>
