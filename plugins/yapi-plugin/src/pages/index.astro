---
import SiteLayout from '../layouts/SiteLayout.astro';

const workflows = [
  {
    title: 'Setup without drift',
    description: 'Check whether yapi exists, install @leeguoo/yapi-mcp when it does not, and keep the environment ready inside Cursor.',
  },
  {
    title: 'Reuse the login you already trust',
    description: 'No second auth model. The plugin keeps using ~/.yapi/config.toml and the upstream yapi login flow.',
  },
  {
    title: 'Move from search to sync',
    description: 'Look up interfaces, inspect details, list category APIs, and jump into docs-sync without leaving the editor.',
  },
];

const commands = [
  'Setup YApi',
  'Login YApi',
  'Who Am I',
  'Search Interface',
  'Get Interface By ID',
  'List Category Interfaces',
  'Bind Docs Sync',
  'Run Docs Sync',
];

const setupExample = `$ node scripts/setup-yapi.mjs
{
  "ok": true,
  "code": "OK",
  "autoInstalled": true,
  "message": "YApi CLI was installed and is ready to use."
}`;
const basePath = import.meta.env.BASE_URL;
const withBase = (path = '') => `${basePath.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<SiteLayout title="YApi Plugin for Cursor" description="A GitHub Pages home for the YApi Cursor plugin. Learn what it does, how it works, and where to start.">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Cursor plugin + GitHub Pages</p>
      <h1>Bring your existing YApi workflow into Cursor.</h1>
      <p class="hero-lead">
        YApi Plugin wraps the local <code>yapi</code> CLI so Cursor can install it automatically, reuse your
        current login state, inspect interfaces, and run docs-sync workflows from one place.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={withBase('docs/getting-started/')}>Start with setup</a>
        <a class="button button-secondary" href="https://github.com/leeguooooo/yapi-plugin">View repository</a>
      </div>
      <div class="hero-meta">
        <span>Uses the local CLI</span>
        <span>Reuses ~/.yapi/config.toml</span>
        <span>No MCP required in v1</span>
      </div>
    </div>
    <div class="hero-panel">
      <div class="terminal-card">
        <div class="terminal-dots">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <pre><code>{setupExample}</code></pre>
      </div>
      <div class="badge-grid">
        <div class="mini-card">
          <strong>Auto install</strong>
          <span>Detects missing yapi and installs it through npm.</span>
        </div>
        <div class="mini-card">
          <strong>Interface lookup</strong>
          <span>Search keywords, fetch by ID, and list category APIs.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Why this plugin</p>
      <h2>Keep the workflow you already use, remove the parts that slow it down.</h2>
    </div>
    <div class="card-grid">
      {workflows.map((workflow) => (
        <article class="feature-card">
          <h3>{workflow.title}</h3>
          <p>{workflow.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">How it works</p>
      <h2>A narrow first release with clear boundaries.</h2>
      <ol class="timeline">
        <li>Check whether <code>yapi</code> is on PATH.</li>
        <li>Install <code>@leeguoo/yapi-mcp</code> globally when it is missing.</li>
        <li>Validate login state with <code>yapi whoami</code>.</li>
        <li>Expose setup, query, and docs-sync flows as Cursor skills and commands.</li>
      </ol>
    </div>
    <div class="surface-card">
      <p class="surface-title">Primary workflows</p>
      <ul class="tag-list">
        {commands.map((command) => (
          <li>{command}</li>
        ))}
      </ul>
      <a class="text-link" href={withBase('docs/commands/')}>Browse command details</a>
    </div>
  </section>

  <section class="section callout">
    <div>
      <p class="eyebrow">Docs site starts here</p>
      <h2>This homepage is the front door. The docs area is already live.</h2>
      <p>
        The current Pages release keeps the top level focused on product value and routes deeper usage into a small
        docs area. That gives the project a clean marketing surface today without blocking a larger documentation site
        tomorrow.
      </p>
    </div>
    <div class="callout-actions">
      <a class="button button-primary" href={withBase('docs/')}>Open docs</a>
      <a class="button button-secondary" href={withBase('docs/development/')}>Developer notes</a>
    </div>
  </section>
</SiteLayout>
